# Public Appwrite runtime config for Netherite desktop builds.
# These values are safe to ship in the desktop app.
# Do not put APPWRITE_API_KEY or any admin secret in this file.

# Core Appwrite project info
VITE_APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_public_project_id
VITE_APPWRITE_DATABASE_ID=your_public_database_id

# Database collections used by auth, sync, and gacha
VITE_APPWRITE_USER_SETTINGS_COLLECTION_ID=user_settings
VITE_APPWRITE_VAULT_SNAPSHOTS_COLLECTION_ID=vault_snapshots
VITE_APPWRITE_SYNC_MANIFESTS_COLLECTION_ID=sync_manifests
VITE_APPWRITE_GACHA_USERS_COLLECTION_ID=gacha_users
VITE_APPWRITE_GACHA_INVENTORY_COLLECTION_ID=gacha_inventory
VITE_APPWRITE_GACHA_COSMETICS_COLLECTION_ID=gacha_cosmetics
VITE_APPWRITE_GACHA_CHESTS_COLLECTION_ID=gacha_chests

# Storage buckets
VITE_APPWRITE_SNAPSHOTS_BUCKET_ID=snapshots
VITE_APPWRITE_AVATARS_BUCKET_ID=avatars

# Appwrite function IDs
VITE_APPWRITE_OPEN_CHEST_FUNCTION_ID=your_open_chest_function_id
VITE_APPWRITE_SYNC_GACHA_PROFILE_FUNCTION_ID=your_sync_gacha_profile_function_id

# Optional local AI key. Keep this local only.
GROQ_API_KEY=your_groq_api_key_here
