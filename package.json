{
  "name": "netherite",
  "version": "1.0.0",
  "description": "Your second brain. Built different.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "npm run build && electron-builder --win nsis",
    "pack:win": "npm run build && electron-builder --win --dir",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "prechaos:api": "python -m uvicorn main:app --app-dir prechaos/backend --host 127.0.0.1 --port 8765",
    "prechaos:requirements": "python -m pip install -r prechaos/backend/requirements.txt",
    "prechaos:train": "python -c \"from prechaos.backend.app.training import train_from_dataset; import sys; print(train_from_dataset(sys.argv[1]).metrics)\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@lezer/highlight": "^1.2.3",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/face_mesh": "^0.4.1657299874",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@types/d3": "^7.4.3",
    "appwrite": "^24.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "date-fns": "4.1.0",
    "dompurify": "^3.3.3",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.564.0",
    "mermaid": "^11.13.0",
    "pixi.js": "^8.16.0",
    "react": "^18.3.1",
    "react-day-picker": "9.13.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.28.0",
    "recharts": "2.15.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "unzipper": "^0.12.3",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@swc/core": "^1.15.21",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "node-appwrite": "^23.1.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.netherite.desktop",
    "productName": "Netherite",
    "icon": "app-icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "app-icon.png",
      "app-icon.ico"
    ],
    "extraResources": [
      {
        "from": "prechaos/backend",
        "to": "prechaos/backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!data/live_*.jsonl"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
